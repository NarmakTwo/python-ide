var myCodeMirror;
globalThis.myCodeMirror = null;
if (navigator.serviceWorker) {
    navigator.serviceWorker.register('sw.js');
}

window.addEventListener('load', function() {
    editorpage = document.getElementById("editor");
    myCodeMirror = CodeMirror(editorpage, {
        value: "# Welcome to Nuilith IDE\n",
        mode: "python",
        theme: "programiz",
        lineNumbers: true,
        indentUnit: 2,
        tabSize: 2,
        indentWithTabs: false,
        smartIndent: true,
        electricChars: true,
        lineWrapping: false,
        autofocus: true,
        undoDepth: 200,
        historyEventDelay: 1000,
        cursorBlinkRate: 530,
        cursorScrollMargin: 4,
        cursorHeight: 1,
        lineWiseCopyCut: true,
        dragDrop: true,
        viewportMargin: 50,            // render extra lines above/below for smoother scroll
        maxHighlightLength: 50000,
        fixedGutter: true,
        gutters: ["CodeMirror-linenumbers", "CodeMirror-foldgutter"],
        scrollbarStyle: "native",
        inputStyle: "textarea",
        extraKeys: {
            "Tab": (cm) => {
                if (cm.somethingSelected()) {
                    cm.indentSelection("add");
                } else {
                    cm.replaceSelection("  ", "end"); // 2 spaces instead of tab char
                }
            },
            "Shift-Tab": (cm) => cm.indentSelection("subtract"),
            "Ctrl-/": "toggleComment",             // needs addon/comment/comment.js
            "Ctrl-Z": "undo",
            "Ctrl-Y": "redo",
            "Ctrl-D": "deleteLine",
            "Ctrl-F": "findPersistent",            // needs addon/search
            "Ctrl-H": "replace",                   // needs addon/search
            "Ctrl-G": "jumpToLine",                // needs addon/search
            "Alt-Up": "swapLineUp",                // needs addon/move-lines
            "Alt-Down": "swapLineDown",
            "Ctrl-]": (cm) => cm.indentSelection("add"),
            "Ctrl-[": (cm) => cm.indentSelection("subtract"),
        }
    });
});

function evaluate(command, term) {
    switch (command) {
        case "python3":
            // run repl

            break;
        case 'python3 main.py':
            execute(myCodeMirror.getValue());
        case "clear":
            term.clear();
            break;
        case "python":
            // run repl

            break;
        case 'python main.py':
            execute(myCodeMirror.getValue());
        case "fuck":
            return `It's ok, you'll figure it out.`;
        case "help":
            return `You can run python3, clear, or help.`;
        case "FUCK":
            return `It's ok, you'll figure it out.`;
        default:
            return `Unknown command: ${command}\nType 'help' for a list of commands.`;
    }
}

let term;

jQuery(function($, undefined) {
    term = $('#terminal').terminal(function(command) {
        term.echo(evaluate(command, term));
    }, {
        greetings: 'Welcome to Nuilith IDE',
        name: 'nuilith',
    });
});

function runcode() {
    term.exec('python3 main.py', true);
}

function repl() {
    term.exec("python3");
}




function execute(code) {
    // add functionality later
}

function savecode() {
    console.log('saving code');
    code = myCodeMirror.getValue();
    const a = document.createElement('a');
    const file = new Blob([code], { type: 'text/x-python' });
    a.href = URL.createObjectURL(file);
    a.download = 'main.py';
    a.click();
    URL.revokeObjectURL(a.href); // Clean up the object URL
}

async function loadcode() {
    console.log('loading code');
    const file = await window.showOpenFilePicker({
        multiple: false,
        types: [
            {
                description: 'Python Files',
                accept: {
                    'text/x-python': ['.py']
                }
            }
        ]});
    const fileHandle = await file[0].getFile();
    const fileContents = await fileHandle.text();
    myCodeMirror.setValue(fileContents);
}

// make new save database if none exists
indexedDB.open('nuilithdb', 1).onupgradeneeded = function(e) {
    const db = e.target.result;
    // Safety check: only create if it doesn't exist
    if (!db.objectStoreNames.contains('autosave')) {
        db.createObjectStore('autosave', { keyPath: 'id' });
    }
};

globalThis.autosaveTime = 0;

function saveToIDB() {
    const code = myCodeMirror.getValue();
    const request = indexedDB.open('nuilithdb', 1);

    request.onsuccess = function(e) {
        const db = e.target.result;
        const tx = db.transaction('autosave', 'readwrite');
        const store = tx.objectStore('autosave');

        // FIX: Use .put() so it overwrites ID 1 every time
        store.put({ id: 1, code: code });

        tx.oncomplete = function() {
            // Update the global timer reference after a successful save
            globalThis.autosaveTime = Math.floor(Date.now() / 1000);
            db.close();
        };
    };
}

function loadFromIDB() {
    const request = indexedDB.open('nuilithdb', 1);
    request.onsuccess = function(e) {
        const db = e.target.result;
        
        // Prevent errors if the store wasn't created yet
        if (!db.objectStoreNames.contains('autosave')) return;

        const tx = db.transaction('autosave', 'readonly');
        const store = tx.objectStore('autosave');
        const getReq = store.get(1);

        getReq.onsuccess = function() {
            if (getReq.result && myCodeMirror) {
                myCodeMirror.setValue(getReq.result.code);
            }
            db.close();
        };
    };
}


window.addEventListener('load', function() {
    loadFromIDB();
    autosaveTime = Math.floor(Date.now() / 1000);

    setInterval(() => {
        saveToIDB();
        autosaveTime = Math.floor(Date.now() / 1000);
    }, 30000)

    setInterval(() => {
        document.getElementById("autosavetime").innerHTML = `${Math.floor(Date.now() / 1000) - autosaveTime}s`;
    }, 1000)
});

window.addEventListener('beforeunload', function() {
    saveToIDB();
});